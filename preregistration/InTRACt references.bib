@article{kaplonFrameworkDevelopingText2026,
  title = {A framework for developing a text simplification index: {{Design}}, validation, visualization},
  shorttitle = {A framework for developing a text simplification index},
  author = {Kapłon, Robert and Piekot, Tomasz},
  date = {2026-09-01},
  journaltitle = {Information Processing \& Management},
  shortjournal = {Information Processing \& Management},
  volume = {63},
  number = {6},
  pages = {104747},
  issn = {0306-4573},
  doi = {10.1016/j.ipm.2026.104747},
  url = {https://www.sciencedirect.com/science/article/pii/S030645732600138X},
  urldate = {2026-04-16},
  abstract = {In the rapidly developing field of text simplification, there is a significant gap between the paradigms of machine and manual simplification. Social and regulatory pressure creates a need for rapid and widespread improvement in text comprehensibility, while plain language guidelines (e.g., ISO 24495-1:2023) discourage the use of machine tools and readability metrics. In this paper, we attempt to bridge this gap. We propose the Text Simplification Index (TSI), a new framework for evaluating the degree of text simplification. TSI assesses the similarity of a given text to the key linguistic features of naturally simple and widely read texts. We identified these features by comparing a positive benchmark corpus (3917 online media texts) with a negative one (2160 official texts requiring simplification). To verify the performance of TSI, we conducted a study with 24 experienced plain language experts who were asked to evaluate 21 texts. The correlation between the experts’ judgment and the TSI diagnosis was 0.67—higher than the correlations of other readability formulas. We also verified the possibility of modifying TSI variables during the text simplification process. For this purpose, we conducted a quasi-experiment where 306 domain experts, after a brief plain language course, simplified 14 texts. The results showed that all TSI components can be modified by domain experts, although the degree of improvement for a given feature depends on its type, the expert’s skills, and the text topic. Our framework culminates in the design of a practical infographic that precisely shows authors, editors, and researchers the progress in text simplification across each feature.},
  keywords = {Plain language standard,Readability,Readability formulas,Text simplification},
  file = {C\:\\Users\\pablob\\Zotero\\storage\\MNRUF7Z9\\Kapłon and Piekot - 2026 - A framework for developing a text simplification index Design, validation, visualization.pdf;C\:\\Users\\pablob\\Zotero\\storage\\5PG8BB4G\\S030645732600138X.html}
}

@article{karimiGoodenoughLinguisticRepresentations2016,
  title = {Good-enough linguistic representations and online cognitive equilibrium in language processing},
  author = {Karimi, Hossein and Ferreira, Fernanda},
  date = {2016-05},
  journaltitle = {Quarterly Journal of Experimental Psychology},
  shortjournal = {Quarterly Journal of Experimental Psychology},
  volume = {69},
  number = {5},
  pages = {1013--1040},
  issn = {1747-0218, 1747-0226},
  doi = {10.1080/17470218.2015.1053951},
  url = {https://journals.sagepub.com/doi/10.1080/17470218.2015.1053951},
  urldate = {2026-05-01},
  abstract = {We review previous research showing that representations formed during language processing are sometimes just “good enough” for the task at hand and propose the “online cognitive equilibrium” hypothesis as the driving force behind the formation of good-enough representations in language processing. Based on this view, we assume that the language comprehension system by default prefers to achieve as early as possible and remain as long as possible in a state of cognitive equilibrium where linguistic representations are successfully incorporated with existing knowledge structures (i.e., schemata) so that a meaningful and coherent overall representation is formed, and uncertainty is resolved or at least minimized. We also argue that the online equilibrium hypothesis is consistent with current theories of language processing, which maintain that linguistic representations are formed through a complex interplay between simple heuristics and deep syntactic algorithms and also theories that hold that linguistic representations are often incomplete and lacking in detail. We also propose a model of language processing that makes use of both heuristic and algorithmic processing, is sensitive to online cognitive equilibrium, and, we argue, is capable of explaining the formation of underspecified representations. We review previous findings providing evidence for underspecification in relation to this hypothesis and the associated language processing model and argue that most of these findings are compatible with them.},
  langid = {english}
}

