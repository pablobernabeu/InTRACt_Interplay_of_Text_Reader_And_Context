@incollection{kaupInterplayModalAmodal2025,
  title = {The interplay of modal and amodal processes in language comprehension at the word level and beyond},
  booktitle = {Psychology of {{Learning}} and {{Motivation}}},
  author = {Kaup, Barbara and Günther, Fritz and Dudschig, Carolin},
  date = {2025-08-28},
  publisher = {Academic Press},
  doi = {10.1016/bs.plm.2025.08.001},
  url = {https://www.sciencedirect.com/science/article/pii/S0079742125000271},
  urldate = {2025-09-18},
  abstract = {According to the grounded framework of language comprehension, sensorimotor processes play an important role for language comprehension: Comprehenders are assumed to mentally simulate the objects, situations and events referred to in the linguistic input. More specifically, it is usually assumed that words automatically activate experiential traces that stem from the comprehenders’ interactions with the referents of these words. When words appear in larger units, the activated experiential traces are presumably combined to yield an experiential simulation consistent with the meaning of the larger phrase or sentence. Thus, accounts in this framework postulate that language comprehension is based on purely modal meaning representations. In this review paper, we will discuss experimental work conducted to investigate these assumptions. The results of these studies call into question that grounded representations are the only meaning representations utilized in language comprehension. Instead, they speak for a more hybrid view of language comprehension, according to which comprehenders make use of both modal and amodal representations during comprehension, including representations of the linguistic experiences people have had. In our chapter we first address broader theoretical issues surrounding mental representations in cognitive psychology and then narrow the focus to language comprehension, tracing how representational debates have shaped the field over the past 25 years. We then outline competing models, review the empirical evidence supporting the proposed model components, and conclude by synthesizing insights and proposing directions for future research.},
  keywords = {Composition,Embodied cognition,Experiential simulations,Language comprehension,Linguistic experiences},
  file = {C\:\\Users\\pablob\\Zotero\\storage\\2PSYTEL7\\Kaup et al. - 2025 - The interplay of modal and amodal processes in language comprehension at the word level and beyond.pdf;C\:\\Users\\pablob\\Zotero\\storage\\4C5XQS74\\S0079742125000271.html}
}

