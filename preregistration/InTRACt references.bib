  urldate = {2026-03-13},
  abstract = {Extensive research has shown that children’s early words are learned through sensorimotor experience. Thus, early-acquired words tend to have more concrete meanings. Abstract word meanings tend to be learned later but less is known about their acquisition. We collected meaning-specific concreteness ratings and examined their relationship with age-of-acquisition data from large-scale vocabulary testing with children in grade 2 to college age. Earlier-acquired meanings were rated as more concrete while later-acquired meanings as more abstract, particularly for words typically considered to be concrete. The results suggest that sensorimotor experiences are important to early-acquired word meanings, and other experiences (e.g., linguistic) are important to later-acquired meanings, consistent with a multi-representational view of lexical semantics.},
