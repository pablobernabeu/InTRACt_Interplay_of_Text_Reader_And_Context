@article{delageSyntaxWorkingMemory2019,
  title = {Syntax and working memory in typically-developing children: {{Focus}} on syntactic complexity},
  shorttitle = {Syntax and working memory in typically-developing children},
  author = {Delage, Hélène and Frauenfelder, Ulrich Hans},
  date = {2019-11-04},
  journaltitle = {Language, Interaction and Acquisition},
  volume = {10},
