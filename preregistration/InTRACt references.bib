@article{vonhagenForeignLanguageAttainment2021,
  title = {Foreign language attainment of children/adolescents with poor literacy skills: a systematic review and meta-analysis},
  shorttitle = {Foreign language attainment of children/adolescents with poor literacy skills},
  author = {Von Hagen, Alexa and Kohnen, Saskia and Stadie, Nicole},
  date = {2021-06},
  journaltitle = {Educational Psychology Review},
  shortjournal = {Educ Psychol Rev},
  volume = {33},
