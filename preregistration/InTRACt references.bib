@article{hartExpandingEnvironmentGene2013,
  title = {Expanding the environment: gene × school‐level {{SES}} interaction on reading comprehension},
  shorttitle = {Expanding the environment},
  author = {Hart, Sara A. and Soden, Brooke and Johnson, Wendy and Schatschneider, Christopher and Taylor, Jeanette},
  date = {2013-10},
  journaltitle = {Journal of Child Psychology and Psychiatry},
