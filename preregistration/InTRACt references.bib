@article{massonnieIndividualDifferencesDealing2022,
  title = {Individual differences in dealing with classroom noise disturbances},
  author = {Massonnié, Jessica and Mareschal, Denis and Kirkham, Natasha Z.},
  date = {2022-08},
  journaltitle = {Mind, Brain, and Education},
  shortjournal = {Mind Brain and Education},
