@article{mouwContributionsEmotionUnderstanding2019,
  title = {Contributions of emotion understanding to narrative comprehension in children and adults},
  author = {Mouw, Jolien M. and Van Leijenhorst, Linda and Saab, Nadira and Danel, Marleen S. and family=Broek, given=Paul, prefix=van den, useprefix=true},
  date = {2019-01-02},
  journaltitle = {European Journal of Developmental Psychology},
  volume = {16},
