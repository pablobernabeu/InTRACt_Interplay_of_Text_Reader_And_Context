@article{wagnerModelbasedMetaanalyticExamination2021,
  title = {A model-based meta-analytic examination of specific reading comprehension deficit: how prevalent is it and does the simple view of reading account for it?},
  shorttitle = {A model-based meta-analytic examination of specific reading comprehension deficit},
  author = {Wagner, Richard K. and Beal, Bethany and Zirps, Fotena A. and Spencer, Mercedes},
  date = {2021-07-01},
  journaltitle = {Annals of Dyslexia},
  shortjournal = {Ann. of Dyslexia},
  volume = {71},
