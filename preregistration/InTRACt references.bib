@article{wangReciprocalEffectsVocabulary2025,
  title = {Reciprocal effects of vocabulary breadth, vocabulary depth, and reading comprehension: a cross-lagged panel analysis in {{Chinese-speaking EFL}} learners},
  shorttitle = {Reciprocal effects of vocabulary breadth, vocabulary depth, and reading comprehension},
  author = {Wang, Tuoxiong and Zhang, Haomin},
